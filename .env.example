# Download URL base for .icns files.
# In development: leave unset to use local /public/icns/ files.
# In production: set to the public URL of your storage bucket.
#
# Examples:
#   Cloudflare R2:  https://pub-xxxxx.r2.dev
#   AWS S3:         https://my-bucket.s3.amazonaws.com
#   Custom domain:  https://icns.example.com
NEXT_PUBLIC_ICNS_BASE_URL=
