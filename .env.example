# GitHub Raw base URL for serving icns downloads and full-size PNG previews.
# Replace with your own repo path if you fork this project.
NEXT_PUBLIC_GITHUB_RAW=https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/public

# Set when deploying to GitHub Pages project page (e.g. /mac-folder-icns).
# Leave empty for custom domains or Vercel.
NEXT_PUBLIC_BASE_PATH=
